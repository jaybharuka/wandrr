# Email Configuration for OTP Service
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=solo_travel_app

# Server Configuration
PORT=5000

# Duffel Flight API (https://duffel.com — free test account)
DUFFEL_API_KEY=duffel_test_your_key_here

# Google Gemini AI API (https://aistudio.google.com — free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Note: For Gmail, you need to:
# 1. Enable 2-factor authentication
# 2. Generate an app-specific password
# 3. Use that app password here (not your regular Gmail password)
#
# For other email providers, adjust the service in otpService.js
# 
# SMS Configuration (for future implementation)
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=your-twilio-phone